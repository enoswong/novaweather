# 修改說明：提供本地開發環境變數範本（不含任何真實金鑰）
# 影響文件：.env.example

# ── Supabase (本地/雲端擇一) ─────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
# ⚠️ 禁止將 service role key 提供給前端/客戶端；僅供 Edge Functions 或安全的 scheduler 使用
SUPABASE_SERVICE_ROLE_KEY=

# ── Weather Providers ────────────────────────────────────────
# Open‑Meteo 無需 key
OPEN_METEO_ENABLED=true

# WeatherAPI.com
WEATHER_API_KEY=

# OpenWeather
OPENWEATHER_API_KEY=

# Tomorrow.io
TOMORROW_IO_API_KEY=

